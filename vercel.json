{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/auth/google", "dest": "/api/auth/google.ts" },
    { "src": "/auth/callback", "dest": "/api/auth/callback.ts" },
    { "src": "/api/me", "dest": "/api/me.ts" },
    { "src": "/mcp", "dest": "/api/mcp.ts" }
  ]
}
